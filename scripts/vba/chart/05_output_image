'==============================================================
' 辅助函数: 清理临时chart容器
'==============================================================
Private Sub ClearChartContainer(ByVal ch As Chart)
    
    On Error Resume Next
    
    Do While ch.SeriesCollection.Count > 0
        ch.SeriesCollection(1).Delete
    Loop
    
    ch.HasTitle = False
    
    With ch.ChartArea.Format.Fill
        .Visible = msoTrue
        .ForeColor.RGB = RGB(255, 255, 255)
        .Solid
    End With
    
    ch.ChartArea.Format.Line.Visible = msoFalse
    ch.PlotArea.Format.Fill.Visible = msoFalse
    ch.PlotArea.Format.Line.Visible = msoFalse
    
    ch.Axes(xlCategory).Delete
    ch.Axes(xlValue).Delete
    
    On Error GoTo 0
    
End Sub


'==============================================================
' 辅助函数: 生成临时sheet名称
'==============================================================
Private Function MakeTempSheetName(ByVal prefix As String) As String
    
    Static counter As Long
    
    counter = counter + 1
    MakeTempSheetName = Left(prefix & Format(Timer * 1000, "0") & "_" & counter, 31)
    
End Function


'==============================================================
' 辅助函数: 删除临时sheet，并恢复DisplayAlerts状态
'==============================================================
Private Sub DeleteTempSheet(ByRef tmpSheet As Worksheet)
    
    On Error Resume Next
    
    If Not tmpSheet Is Nothing Then
        
        Dim oldAlerts As Boolean
        oldAlerts = Application.DisplayAlerts
        
        Application.DisplayAlerts = False
        tmpSheet.Delete
        Application.DisplayAlerts = oldAlerts
        
        Set tmpSheet = Nothing
        
    End If
    
    On Error GoTo 0
    
End Sub


'==============================================================
' 辅助函数: 等待指定秒数
'   用途: 给Excel图表渲染留出时间
'==============================================================
Private Sub WaitSeconds(ByVal seconds As Double)
    
    Dim startTime As Double
    startTime = Timer
    
    Do While Timer - startTime < seconds
        DoEvents
    Loop
    
End Sub

